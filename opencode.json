{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "Delegate",
  "agent": {
    "Delegate": {
      "description": "OpenAI orchestration-only primary agent for routing planning and build work through orchestrated OpenCode sessions.",
      "model": "openai/gpt-5.5",
      "mode": "primary",
      "prompt": "{file:./.opencode/delegate_sysprompt.md}",
      "permission": {
        "*": "deny",
        "orchestrator_*": "allow",
        "read": "allow",
        "todowrite": "allow"
      }
    }
  },
  "mcp": {
    "orchestrator": {
      "type": "local",
      "command": [
        "opencode-orchestrator-mcp"
      ],
      "enabled": true
    }
  }
}
